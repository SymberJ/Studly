# Skopiuj ten plik jako .env i uzupełnij wartości z panelu Supabase:
# https://supabase.com → Twój projekt → Settings → API

# Adres projektu (np. https://xyzxyz.supabase.co)
VITE_SUPABASE_URL=

# Klucz publiczny anon (bezpieczny do użycia po stronie klienta)
VITE_SUPABASE_ANON_KEY=

# Bez tych zmiennych aplikacja działa w trybie DEMO (dane w localStorage),
# a panel administratora operuje na lokalnej "bazie" przykładowych studentów.
#
# Po uzupełnieniu zmiennych:
#   1. Wykonaj supabase/schema.sql w SQL Editor (tworzy tabele + RLS + widok admina).
#   2. (Opcjonalnie) wdroż funkcję brzegową, by admin mógł zakładać/usuwać konta:
#        supabase functions deploy admin-users
#        supabase secrets set SERVICE_ROLE_KEY=<service_role z Settings → API>
